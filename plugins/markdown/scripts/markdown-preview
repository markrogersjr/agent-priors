#!/usr/bin/env bash
# best-effort preview; never block the tool on render failures, so drop -e and exit 0 at the end
set -uo pipefail

PAYLOAD=$(cat)

FILE_PATH=$(printf '%s' "$PAYLOAD" | python3 -c 'import sys,json; print(json.load(sys.stdin).get("tool_input",{}).get("file_path",""))')
case "$FILE_PATH" in
    *.md) ;;
    *) exit 0 ;;
esac

TEMP_MD=$(printf '%s' "$PAYLOAD" | python3 "${CLAUDE_PLUGIN_ROOT}/scripts/compose-proposed.py")
[ -n "$TEMP_MD" ] || exit 0

SRCDIR="$(cd "$(dirname "$FILE_PATH")" && pwd)"
OUTPUT="/tmp/markdown-preview/$(basename "$FILE_PATH" .md).html"

pandoc "$TEMP_MD" -s -f gfm \
    --mathjax \
    --metadata title=" " \
    --resource-path="$SRCDIR" \
    -c "https://cdnjs.cloudflare.com/ajax/libs/github-markdown-css/5.5.1/github-markdown-dark.min.css" \
    --template <(echo '<!DOCTYPE html><html><head><meta charset="utf-8"><base href="file://'"$SRCDIR"'/"><style>body{max-width:800px;margin:40px auto;padding:0 20px;background:#0d1117;}</style>$for(css)$<link rel="stylesheet" href="$css$"/>$endfor$$math$</head><body class="markdown-body">$body$</body></html>') \
    -o "$OUTPUT"

open "$OUTPUT"
exit 0
